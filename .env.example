# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase anon (publishable) key — used by client & server with RLS.
SUPABASE_KEY=

# Supabase service role key — SERVER ONLY. Bypasses RLS. Used by server routes
# when upserting into the shared `cards` cache. Never expose to the client.
# (This is the name @nuxtjs/supabase picks up automatically.)
SUPABASE_SERVICE_KEY=
